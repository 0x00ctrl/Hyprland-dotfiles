{
    "layer": "top",
    "position": "top",
    "margin": "4 4 0 4",
    "reload_style_on_change": true,
    
    // --- MODULES LAYOUT ---
    "modules-left": [
        "custom/notification",
        "clock",
        "power-profiles-daemon",
        "battery", 
        "pulseaudio",
        "tray",
        "cava"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "group/hardware",
        "group/connection",
        "custom/quote"
    ],

    // --- WORKSPACES ---
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "ï„‘ ",
            "default": "ï„‘ ",
            "empty": "ï„‘ "
        },
        "persistent-workspaces": {
            "*": [ 1, 2, 3, 4, 5 ]
        }
    },

    // --- GROUPS ---
    "group/power": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "transition-to-left": false,
            "click-to-reveal": true
        },
        "modules": ["power-profiles-daemon", "battery"]
    },

    "group/hardware": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "transition-to-left": true,
            "click-to-reveal": true
        },
        "modules": ["custom/expand", "disk", "cpu", "memory", "temperature","bluetooth"]
    },

    "group/connection": {
        "orientation": "horizontal",
        "modules": ["network"]
    },

    // --- MODULES ---
    "custom/expand": {
        "format": "ï„„",
        "tooltip": false
    },
    "custom/quote": {
       	"exec": "printf '{\"text\": \"What you dont know hinders what you know\"}'",
		//"exec": "printf '{\"text\": \"Don let uni get in the way of yo education.\"}'",
        "return-type": "json"
    },
    "tray": {
            "icon-size": 14,
            "spacing": 10
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}ïٹ”",
        "format-muted": "î»¨ ",
        "format-icons": {
            "headphone": "ï€¥ ",
            "hands-free": "ï–گ",
            "headset": "ï–گ",
            "phone": "ï‚•",
            "portable": "ï‚• ",
            "car": "ï†¹ ",
            "default": ["ï€§ ", "ï€¨ "]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol",
        "ignored-sinks": ["Easy Effects Sink"]
    },
    "custom/notification": {
        "tooltip": false,
        "format": "îڑگ ",
        "on-click": "swaync-client -t -sw",
        "escape": true
    },
    "disk": {
        "interval": 30,
        "format": "َ°‹ٹ {percentage_used}%",
        "path": "/"
    },
    "clock": {
        "format": "ïپ³ {:%a, %b %d | %I:%M %p} ",
        "interval": 1,   
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
                            "mode"          : "year",
                            "mode-mon-col"  : 3,
                            "weeks-pos"     : "right",
                            "on-scroll"     : 1,
                            "format": {
                                      "months":     "<span color='#ffead3'><b>{}</b></span>",
                                      "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                                      "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                                      "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                                      "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                                      }
                            },
        "actions": {
            "on-click": "mode"
        }
    },
    "network": {
        "format-wifi": "ï‡«  â‡£{bandwidthDownBytes} â‡،{bandwidthUpBytes}",
        "format-ethernet": "î¼‰  {ifname} â‡£{bandwidthDownBytes} â‡،{bandwidthUpBytes}",
        "format-disconnected": "î¬پ ",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) {ipaddr}",
        "tooltip-format-ethernet": "{ifname} ًں–§  {ipaddr}",
        "on-click": "kitty nmtui"
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "ïƒ§",
            "performance": "ïƒ§",
            "balanced": "ï‰ژ ",
            "power-saver": "ïپ¬ "
        }
    },
    "bluetooth": {
    	"tooltip": true,
    	"tooltip-format": "{controller_alias}\t{controller_address}",
    	"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    	"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "format-on": "َ°‚¯",
        "format-off": "َ°‚²",
        "format-disabled": "َ°‚²",
        "format-connected-battery": "{device_battery_percentage}% َ°‚¯",
        "format-alt": "{device_alias} َ°‚¯",
        "on-click-right": "blueman-manager"
    }, 
    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% َ°‚„",
        "format-plugged": "{capacity}% َ°‚„ î¬­",
        "format-alt": "{time} {icon}",
        "format-icons": ["َ°پ»", "َ°پ¼", "َ°پ¾", "َ°‚€", "َ°‚‚", "َ°پ¹"]
    },
    "cava": {
        "cava_config": "/home/abrar/.config/cava/config",
        "framerate": 60,
        "autosens": 1,
        "bars": 14,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 10000,
        "method": "pulse",
        "source": "alsa_output.pci-0000_00_1f.3.analog-stereo.monitor",
        "stereo": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.77,
        "input_delay": 2,
        "format-icons": [" ", "â–‚", "â–ƒ", "â–„", "â–…", "â–†", "â–‡", "â–ˆ" ],
        "actions": {
            "on-click-right": "mode"
        }
    },
    "cpu": {
        "format": "َ°»  {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "î؟… {percentage}%"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "ï‹‰ {temperatureC}آ°C"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 10
    }
}
